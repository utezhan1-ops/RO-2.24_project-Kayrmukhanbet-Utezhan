<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SchoolApp.MainPage"
             Title="Home">

    <VerticalStackLayout Padding="20" Spacing="15" VerticalOptions="Center">
        <Label Text="School App"
               FontSize="32"
               HorizontalOptions="Center" />

        <Label Text="Powered by .NET 10 MAUI"
               FontSize="16"
               HorizontalOptions="Center" />

        <Label x:Name="StatusLabel"
               Text="Tap the button to confirm everything works."
               FontSize="14"
               HorizontalOptions="Center" />

        <Button Text="Check"
                Clicked="OnTapClicked"
                HorizontalOptions="Center" />

        <Button Text="Open students list"
        Clicked="OnOpenStudentsClicked"
        HorizontalOptions="Center" />

        <Label Text="Name card" FontSize="22" FontAttributes="Bold" />

        <Entry  Text="{Binding Name}" Placeholder="Edit your name" />

        <Label  Text="{Binding Name}" FontSize="20" />
        <Label  Text="{Binding City}" FontSize="16" TextColor="Gray" />
        <Button Text="Shout the name"
        Clicked="OnShoutClicked" />
        <Entry Text="{Binding NewName, Mode=TwoWay}" 
       Placeholder="Введите имя студента" />

        <Button Text="Add" 
        Command="{Binding AddStudentCommand}" />

    </VerticalStackLayout>

</ContentPage>