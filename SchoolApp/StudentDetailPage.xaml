<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SchoolApp.StudentDetailPage"
             Title="Student">

    <VerticalStackLayout Padding="20" Spacing="10">
        <Label x:Name="NameLabel" FontSize="28" HorizontalOptions="Center"/>
        <Label x:Name="DetailsLabel" FontSize="16" HorizontalOptions="Center"/>
        <Button Text="Back" Clicked="OnBackClicked" HorizontalOptions="Center"/>
    </VerticalStackLayout>

</ContentPage>